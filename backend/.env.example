# ---------------------------------------------------------------------------
# Backend EmotionLens — exemplo de variáveis de ambiente.
#
# Copie este arquivo para `.env` na pasta backend/ e ajuste conforme sua máquina.
# NUNCA versione o arquivo `.env` real (ele está no .gitignore).
# Todas as variáveis usam o prefixo EMOTIONLENS_.
# Os valores abaixo são apenas EXEMPLOS/padrões — nada sensível.
# ---------------------------------------------------------------------------

# Origens permitidas para CORS (frontend Vite). Formato JSON (lista).
EMOTIONLENS_CORS_ORIGINS=["http://localhost:5173","http://127.0.0.1:5173"]

# Tamanho máximo de upload em bytes (padrão: 200 MB).
EMOTIONLENS_MAX_UPLOAD_BYTES=209715200

# Backend de detecção de faces do DeepFace:
#   opencv (leve, padrão) | ssd | mtcnn | retinaface (mais preciso, mais pesado)
EMOTIONLENS_DETECTOR_BACKEND=opencv

# Lança erro quando nenhuma face é encontrada (usado para contar faces).
EMOTIONLENS_ENFORCE_DETECTION=true

# Nº de frames amostrados por vídeo (quantidade de pontos da linha do tempo).
EMOTIONLENS_FRAME_SAMPLE_COUNT=30

# Teto de frames decodificados por vídeo (evita processar vídeos longos inteiros).
EMOTIONLENS_MAX_FRAMES_ANALYZED=300

# Ativa modo debug (logs mais verbosos). Use false em apresentação.
EMOTIONLENS_DEBUG=false
