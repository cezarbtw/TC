# Configuração do backend EmotionLens (copie para .env e ajuste se necessário).
# Todas as variáveis usam o prefixo EMOTIONLENS_.

# Origens permitidas para CORS (frontend Vite). Separe por vírgula em JSON.
# EMOTIONLENS_CORS_ORIGINS=["http://localhost:5173","http://127.0.0.1:5173"]

# Backend de detecção de faces do DeepFace: opencv | ssd | mtcnn | retinaface
# EMOTIONLENS_DETECTOR_BACKEND=opencv

# Nº de frames amostrados por vídeo (pontos da linha do tempo).
# EMOTIONLENS_FRAME_SAMPLE_COUNT=30

# Teto de frames decodificados por vídeo.
# EMOTIONLENS_MAX_FRAMES_ANALYZED=300

# Tamanho máximo de upload em bytes (padrão 200 MB).
# EMOTIONLENS_MAX_UPLOAD_BYTES=209715200
