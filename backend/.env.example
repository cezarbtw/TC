# ---------------------------------------------------------------------------
# Backend EmotionLens — exemplo de variáveis de ambiente.
#
# Copie este arquivo para `.env` na pasta backend/ e ajuste conforme sua máquina.
# NUNCA versione o arquivo `.env` real (ele está no .gitignore).
# Todas as variáveis usam o prefixo EMOTIONLENS_.
# Os valores abaixo são apenas EXEMPLOS/padrões — nada sensível.
# ---------------------------------------------------------------------------

# Origens permitidas para CORS (frontend Vite). Formato JSON (lista).
EMOTIONLENS_CORS_ORIGINS=["http://localhost:5173","http://127.0.0.1:5173"]

# Tamanho máximo de upload em bytes (padrão: 200 MB).
EMOTIONLENS_MAX_UPLOAD_BYTES=209715200

# Dispositivo de inferência: auto (GPU se houver, senão CPU) | cpu | cuda
EMOTIONLENS_DEVICE=auto

# Taxa de amostragem alvo do vídeo (FPS analisados; não processa todos os frames).
EMOTIONLENS_TARGET_FPS=5

# Teto de frames analisados por vídeo (evita processar vídeos longos inteiros).
EMOTIONLENS_MAX_FRAMES_ANALYZED=600

# Detector de faces (YOLOv8-face) — nome/caminho dos pesos.
EMOTIONLENS_FACE_DETECTOR_MODEL=yolov8n-face.pt

# Confiança mínima da detecção de face (0..1).
EMOTIONLENS_MIN_DETECTION_CONFIDENCE=0.5

# Lado mínimo (px) da face; faces menores são ignoradas.
EMOTIONLENS_MIN_FACE_SIZE=48

# Modelo de classificação emocional HSEmotion (7 classes).
EMOTIONLENS_EMOTION_MODEL_NAME=enet_b2_7

# Janela (nº de frames) da média móvel para suavização temporal.
EMOTIONLENS_SMOOTHING_WINDOW=5

# Ativa modo debug (logs mais verbosos). Use false em apresentação.
EMOTIONLENS_DEBUG=false
